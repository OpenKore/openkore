 					$self->{plugin_retry} = 0;
 				}
 				my %plugin_args = (
 					'x'            => $self->{x},
 					'y'            => $self->{y},
 					'nameID'       => $self->{nameID},
 					'sequence'     => $self->{sequence},
 					'plugin_retry' => $self->{plugin_retry},
 					'return'       => 0
 				);
 
